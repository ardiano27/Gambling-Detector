{
  "manifest_version": 3,
  "name": "Gambling Detector",
  "description": "Detects gambling-related content on web pages and warns the user.",
  "version": "0.1.0",
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Gambling Detector"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/detection/rule-based.js",
        "src/detection/engine.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options.html",
  "permissions": [
    "activeTab",
    "storage"
  ]
}
